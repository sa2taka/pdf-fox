{
  "name": "pdf-fox",
  "version": "1.3.0",
  "description": "PDF to PNG converter using PDF.js",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "pdf-fox": "dist/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "prepare": "tsc",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "pdf",
    "png",
    "converter",
    "pdfjs"
  ],
  "author": "sa2taka <sa2taka@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sa2taka/pdf-fox.git"
  },
  "bugs": {
    "url": "https://github.com/sa2taka/pdf-fox/issues"
  },
  "homepage": "https://github.com/sa2taka/pdf-fox#readme",
  "dependencies": {
    "@napi-rs/canvas": "^1.0.0",
    "pdfjs-dist": "^6.0.227"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
